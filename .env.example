# ---------------------------------------------------------------------------
# .env.example  ->  copy to  .env  and fill in your own values.
#
#   cp .env.example .env
#
# This project uses Snowflake EXTERNAL BROWSER authentication.
# DO NOT put a password here - none is required. When you connect, Snowflake
# opens your browser for SSO / login.
#
# The .env file is for YOUR machine only. Never commit it to git.
# ---------------------------------------------------------------------------

# Your Snowflake account identifier, e.g. abcd-xy12345  (from the account URL).
SNOWFLAKE_ACCOUNT=your_account_locator

# Your Snowflake login/user name.
SNOWFLAKE_USER=your_username

# --- Authentication ---------------------------------------------------------
# Choose ONE mode:
#
#  (A) Interactive, for running things by hand (default). Opens a browser for
#      SSO login. No password stored. CANNOT run unattended.
SNOWFLAKE_AUTHENTICATOR=externalbrowser
#
#  (B) Unattended, for the automated refresh job. Uses an RSA key pair on a
#      TYPE=SERVICE user (see sql/07_create_service_user.sql). No password,
#      no browser, no MFA prompt. To use it, set:
#        SNOWFLAKE_AUTHENTICATOR=snowflake_jwt
#        SNOWFLAKE_PRIVATE_KEY_PATH=/secure/path/rsa_key.p8
#        SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=            # only if the key is encrypted
#      and point SNOWFLAKE_USER at the service user (e.g. SVC_AI_LABOR_LOADER).
# SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Role that can create/read the objects (SYSADMIN works for interactive setup;
# use AI_LABOR_LOADER for the automated service user).
SNOWFLAKE_ROLE=SYSADMIN

# Objects created by sql/00_create_environment.sql.
SNOWFLAKE_WAREHOUSE=AI_LABOR_WH
SNOWFLAKE_DATABASE=AI_LABOR_ANALYTICS
SNOWFLAKE_SCHEMA=RAW
